# DeepL API key (paid plan required for Voice API)
DEEPL_AUTH_KEY=
# Alias supported by config
DEEPL_API_KEY=

# Use api-free.deepl.com for free tier text API; Voice API uses api.deepl.com
DEEPL_API_URL=https://api.deepl.com

PORT=3001
CLIENT_ORIGIN=http://localhost:5173

# Optional: require token on Socket.IO handshake (io({ auth: { token: '...' } }))
SOCKET_SECRET=

# Max PCM bytes per socket per second (default 160000)
MAX_AUDIO_BYTES_PER_SEC=160000

# Database (Prisma) — MySQL
# Create the database first, e.g.:
#   CREATE DATABASE ison_translate CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;
DATABASE_URL="mysql://USER:PASSWORD@localhost:3306/ison_translate"

# Session history persistence
PERSIST_ENABLED=true
PERSIST_AUDIO=true
RECORDINGS_DIR=./storage/recordings
RECORDINGS_MAX_BYTES_PER_SESSION=104857600

# Optional: require Bearer token on GET /api/history/*
HISTORY_API_KEY=

# JWT for user authentication
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
